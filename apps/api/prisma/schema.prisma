generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AgencyType {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  agencies Agency[]

  @@map("agency_types")
}

model Agency {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  shortName   String?  @map("short_name")
  typeId      Int      @map("type_id")
  headName    String?  @map("head_name")
  headTitle   String?  @map("head_title")
  description String?
  address     String?
  phone       String?
  email       String?
  website     String?
  region      String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  agencyType   AgencyType    @relation(fields: [typeId], references: [id], onDelete: Cascade)
  news         News[]
  scrapeConfig ScrapeConfig?

  @@map("agencies")
}

enum Role {
  USER
  ADMIN
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model News {
  id          Int       @id @default(autoincrement())
  title       String
  description String?   @db.Text
  content     String?   @db.Text
  url         String    @unique
  publishedAt DateTime? @map("published_at")
  agencyId    Int       @map("agency_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("news")
}

model ScrapeConfig {
  agencyId  Int      @id @map("agency_id")
  selectors Json
  updatedAt DateTime @updatedAt @map("updated_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("scrape_configs")
}

model SystemConfig {
  key       String   @id @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")
}
